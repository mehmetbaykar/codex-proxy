# Copy to .env and fill in the values.

# Required: bearer clients send as `Authorization: Bearer <this>`.
CURSOR_PROXY_API_KEY=change-me

# Host port bound from docker-compose. Container always listens on 3000.
HOST_PORT=3000

# 1 = verbose tracing + raw payload dumps under ./volume/logs/payloads/.
IS_DEBUG=0

# Codex upstream auth — pick ONE path:
#   A) mount your ChatGPT session file: cp ~/.codex/auth.json ./volume/auth/auth.json
#   B) or paste the access token below (leave the mount empty).
CODEX_ACCESS_TOKEN=
