# Copy to .env and fill in the values.

# Required: bearer clients send as `Authorization: Bearer <this>`.
CURSOR_PROXY_API_KEY=change-me

# Host port bound from docker-compose. Container always listens on 3000.
HOST_PORT=3000

# 1 = verbose tracing + raw payload dumps under ./volume/logs/payloads/.
IS_DEBUG=0

# Codex upstream auth: after `docker compose up -d`, run
#   docker exec -it codex-proxy codex-proxy login
# and follow the printed URL + code. Tokens are written to
# ./volume/auth/auth.json and refreshed automatically from then on.
